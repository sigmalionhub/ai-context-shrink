{
  "name": "@sigmalion/ai-context-shrink",
  "version": "1.0.4",
  "description": "Compress objects and text to minimize LLM tokens while preserving clarity",
  "keywords": [
    "llm",
    "ai",
    "context",
    "compress",
    "shrink",
    "tokens",
    "openai",
    "anthropic",
    "prompt"
  ],
  "author": {
    "name": "Roman Polshikov",
    "url": "https://github.com/polshikovrm"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts --out-dir dist",
    "test": "npx tsx index.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sigmalionhub/ai-context-shrink.git"
  }
}
